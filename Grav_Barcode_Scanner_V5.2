// ─── WiFi Update Barcode Handler ──────────────────────────────────────────────
void handleWiFiUpdateBarcode(const String& s) {
  String newSSID, newPass;
  if (!parseWiFiUpdateBarcode(s,newSSID,newPass)) { showVisualFeedback(false,"Bad WiFi barcode"); scanFeedbackUntil=millis()+2000; return; }
  tft.fillScreen(ST77XX_BLACK); drawHeader();
  tft.setTextColor(ST77XX_YELLOW); tft.setTextSize(1); tft.setCursor(5,28); tft.println("WIFI UPDATE");
  tft.setTextColor(ST77XX_WHITE); tft.setCursor(5,42); tft.println("SSID: "+newSSID);
  tft.setTextColor(ST77XX_CYAN); tft.setCursor(5,56); tft.println("Connecting...");
  preferences.begin(CONFIG_NAMESPACE,false);
  preferences.putString("wifi_ssid",newSSID); preferences.putString("wifi_pass",newPass);
  preferences.putBool("wifi_configured",true); preferences.end();
  wifiSSID=newSSID; wifiPass=newPass; wifiConfigured=true;
  WiFi.disconnect(); delay(500); WiFi.mode(WIFI_STA); WiFi.begin(newSSID.c_str(),newPass.c_str());
  int attempts=0; while (WiFi.status()!=WL_CONNECTED&&attempts<20) { delay(500); attempts++; }
  if (WiFi.status()==WL_CONNECTED) {
    wifiConnectionFailCount=0; lastWiFiState=true;
    // Indian NTP server — faster sync from India
    configTime(GMT_OFFSET_SEC,DAYLIGHT_OFFSET_SEC,"in.pool.ntp.org","pool.ntp.org","time.nist.gov");
    for (int i=0;i<50;i++) { time_t n; time(&n); if (n>1700000000UL) break; delay(200); }
    tft.fillScreen(ST77XX_BLACK); drawHeader();
    tft.setTextColor(ST77XX_GREEN); tft.setTextSize(1); tft.setCursor(5,35); tft.println("WiFi Updated!");
    tft.setTextColor(ST77XX_WHITE); tft.setCursor(5,50); tft.println("SSID: "+newSSID);
    tft.setTextColor(ST77XX_CYAN); tft.setCursor(5,65); tft.println("Connected");
    tft.setTextColor(ST77XX_YELLOW); tft.setCursor(5,80); tft.println(WiFi.localIP().toString());
    delay(2500); if (storedScanCount>0) sendBatchNow=true; checkForUpdates(); pollFirebaseOps();
  } else {
    tft.fillScreen(ST77XX_BLACK); drawHeader();
    tft.setTextColor(ST77XX_RED); tft.setTextSize(1); tft.setCursor(5,35); tft.println("WiFi Failed");
    tft.setTextColor(ST77XX_WHITE); tft.setCursor(5,50); tft.println("SSID: "+newSSID);
    tft.setTextColor(ST77XX_YELLOW); tft.setCursor(5,65); tft.println("Check credentials"); delay(3000);
  }
  messageShowUntil=millis()+100; messagePending=true; pendingReturnScreen=isEmployeeSignedIn?"employee":"operator";
}

