    preferences.putBool((p+"isEmp").c_str(),offlineScans[i].isEmployeeScan); preferences.putString((p+"empId").c_str(),offlineScans[i].employeeId);
    preferences.putString((p+"empName").c_str(),offlineScans[i].employeeName); preferences.putString((p+"action").c_str(),offlineScans[i].action);
    preferences.putString((p+"ops").c_str(),offlineScans[i].activeOps);
  }
  preferences.end();
}
void loadScansData() {
  preferences.begin(SCANS_NAMESPACE,true); storedScanCount=preferences.getInt("storedCount",0);
  if (storedScanCount>MAX_STORED_SCANS) storedScanCount=MAX_STORED_SCANS;
  for (int i=0;i<storedScanCount;i++) {
    String p="scan"+String(i);
    offlineScans[i].scanId=preferences.getString((p+"id").c_str(),""); offlineScans[i].timestamp=preferences.getString((p+"ts").c_str(),"");
    offlineScans[i].isEmployeeScan=preferences.getBool((p+"isEmp").c_str(),false); offlineScans[i].employeeId=preferences.getString((p+"empId").c_str(),"");
    offlineScans[i].employeeName=preferences.getString((p+"empName").c_str(),""); offlineScans[i].action=preferences.getString((p+"action").c_str(),"");
    offlineScans[i].activeOps=preferences.getString((p+"ops").c_str(),""); offlineScans[i].retryCount=0;
  }
  preferences.end();
}
