  if (woHistoryCount<MAX_WO_HISTORY) woHistory[woHistoryCount++]=wo;
  else { for (int i=0;i<MAX_WO_HISTORY-1;i++) woHistory[i]=woHistory[i+1]; woHistory[MAX_WO_HISTORY-1]=wo; }
  nvsDirty=true;
}

// ─── Break ────────────────────────────────────────────────────────────────────
bool isBreakBarcode(const String& s) {
  return s.equalsIgnoreCase(BREAK_CODE_WASHROOM)||s.equalsIgnoreCase(BREAK_CODE_BREAKDOWN)||s.equalsIgnoreCase(BREAK_CODE_OTHER);
}
BreakReason parseBreakReason(const String& s) {
  if (s.equalsIgnoreCase(BREAK_CODE_WASHROOM))  return BREAK_WASHROOM;
  if (s.equalsIgnoreCase(BREAK_CODE_BREAKDOWN)) return BREAK_BREAKDOWN;
  if (s.equalsIgnoreCase(BREAK_CODE_OTHER))     return BREAK_OTHER;
  return BREAK_NONE;
}
String breakReasonLabel(BreakReason r) {
  switch(r) { case BREAK_WASHROOM: return "WASHROOM GO"; case BREAK_BREAKDOWN: return "BREAKDOWN"; case BREAK_OTHER: return "OTHER"; default: return ""; }
}
String breakReasonLabelShort(BreakReason r) {
  switch(r) { case BREAK_WASHROOM: return "WASHROOM"; case BREAK_BREAKDOWN: return "BREAKDOWN"; case BREAK_OTHER: return "OTHER"; default: return ""; }
}
bool isInBreakMode() { return currentBreakReason!=BREAK_NONE; }

void saveBreakState() {
  Preferences p; p.begin(BREAK_NAMESPACE,false);
  p.putInt("reason",(int)currentBreakReason); p.putULong64("startEp",(uint64_t)breakStartEpoch);
  p.putBool("synced",breakStartedThisSession); p.end();
}
void loadBreakState() {
  Preferences p; p.begin(BREAK_NAMESPACE,true);
  currentBreakReason=(BreakReason)p.getInt("reason",0);
  breakStartEpoch=(time_t)p.getULong64("startEp",0);
  breakStartedThisSession=p.getBool("synced",false); p.end();
  breakStartMillis=millis();
}
void clearBreakStateNVS() { Preferences p; p.begin(BREAK_NAMESPACE,false); p.clear(); p.end(); }

void startBreak(BreakReason r) {
  currentBreakReason=r; time_t now; time(&now);
  if (now>1700000000UL) { breakStartEpoch=now; breakStartedThisSession=true; }
  else { breakStartEpoch=0; breakStartedThisSession=false; }
  breakStartMillis=millis(); saveBreakState();
  logBreakEventToFirebase(r,"start",0,nullptr);
}
unsigned long getBreakElapsedSeconds() {
  if (currentBreakReason==BREAK_NONE) return 0;
  if (breakStartEpoch>0) { time_t now; time(&now); if (now>1700000000UL&&now>=breakStartEpoch) return (unsigned long)(now-breakStartEpoch); }
  if (breakStartMillis>0) { unsigned long nm=millis(); if (nm>=breakStartMillis) return (nm-breakStartMillis)/1000UL; }
  return 0;
}
void endBreak(const char* endedBy="manual") {
  if (currentBreakReason==BREAK_NONE) return;
  unsigned long elapsed=getBreakElapsedSeconds();
  logBreakEventToFirebase(currentBreakReason,"end",elapsed,endedBy);
  currentBreakReason=BREAK_NONE; breakStartEpoch=0; breakStartedThisSession=false; breakStartMillis=0;
  clearBreakStateNVS();
}
String formatBreakElapsed(unsigned long sec) {
  char buf[16]; snprintf(buf,sizeof(buf),"%02lu:%02lu:%02lu",sec/3600,(sec%3600)/60,sec%60); return String(buf);
}

// ─── Firebase ─────────────────────────────────────────────────────────────────
void pollFirebaseOps() {
  if (!isWiFiConnected()||machineId.length()==0) return;
  HTTPClient http; http.begin(FIREBASE_DB_URL+"/machines/"+machineId+"/activeOps.json"); http.setTimeout(2000);
  int code=http.GET(); if (code!=200) { http.end(); return; }
  String response=http.getString(); http.end(); response.trim();
  if (response==lastActiveOpsCache) return;
  lastActiveOpsCache=response;
  if (response=="null"||response.length()==0) {
    int si=0,so=0; String empty[1]; setActiveOpsFromFirebase(empty,0,si,so);
    if ((si>0||so>0)&&(millis()-lastFirebaseChangeTime>FIREBASE_CHANGE_DEBOUNCE)) {
      lastFirebaseChangeTime=millis();
      if (!isInBreakMode()) { showFirebaseSyncScreen(0,so); messageShowUntil=millis()+2000; messagePending=true; pendingReturnScreen=isEmployeeSignedIn?"employee":"operator"; }
    }
    return;
  }
  StaticJsonDocument<512> doc;
  if (deserializeJson(doc,response)||!doc.is<JsonArray>()) return;
  String desired[MAX_ACTIVE_OPS]; int desiredCount=0;
  for (JsonVariant v:doc.as<JsonArray>()) {
    if (desiredCount>=MAX_ACTIVE_OPS) break;
    String op=v.as<String>(); op.trim(); if (op.length()>0) desired[desiredCount++]=op;
  }
  bool needsUpdate=(desiredCount!=activeOpCount);
  if (!needsUpdate) for (int i=0;i<desiredCount;i++) if (!isOpActive(desired[i])) { needsUpdate=true; break; }
  if (needsUpdate&&(millis()-lastFirebaseChangeTime>FIREBASE_CHANGE_DEBOUNCE)) {
    int si=0,so=0; setActiveOpsFromFirebase(desired,desiredCount,si,so);
    if (si>0||so>0) {
      lastFirebaseChangeTime=millis();
      if (!isInBreakMode()) { showFirebaseSyncScreen(si,so); messageShowUntil=millis()+2000; messagePending=true; pendingReturnScreen=isEmployeeSignedIn?"employee":"operator"; }
    }
  }
}
void pushActiveOpsToFirebase() {
  if (!isWiFiConnected()||machineId.length()==0) return;
  String arr="["; for (int i=0;i<activeOpCount;i++) { if (i>0) arr+=","; arr+="\""+activeOperations[i]+"\""; } arr+="]";
  String payload=(activeOpCount==0)?"null":arr;
  HTTPClient http; http.begin(FIREBASE_DB_URL+"/machines/"+machineId+"/activeOps.json");
  http.addHeader("Content-Type","application/json"); http.setTimeout(3000);
  http.PUT(payload); http.end(); lastActiveOpsCache=payload;
}
void logBreakEventToFirebase(BreakReason reason, const char* action, unsigned long durationSec, const char* endedBy) {
  if (reason==BREAK_NONE||!isWiFiConnected()||machineId.length()==0) return;
  StaticJsonDocument<512> doc;
  doc["reason"]=breakReasonLabelShort(reason); doc["reasonFull"]=breakReasonLabel(reason);
  doc["action"]=action; doc["timestamp"]=getISOTimeIST();
  doc["employeeId"]=currentEmployeeId; doc["employeeName"]=currentEmployeeName;
  doc["machineId"]=machineId; doc["machineName"]=machineName; doc["deviceId"]=deviceId;
  time_t nowEpoch; time(&nowEpoch); if (nowEpoch>1700000000UL) doc["epoch"]=(uint32_t)nowEpoch;
  if (strcmp(action,"start")==0) { if (breakStartEpoch>0) doc["startEpoch"]=(uint32_t)breakStartEpoch; }
  else { doc["durationSec"]=(uint32_t)durationSec; doc["durationFmt"]=formatBreakElapsed(durationSec); if (endedBy) doc["endedBy"]=endedBy; if (breakStartEpoch>0) doc["startEpoch"]=(uint32_t)breakStartEpoch; }
  String payload; serializeJson(doc,payload);
  HTTPClient http; http.begin(FIREBASE_DB_URL+"/machines/"+machineId+"/breakEvents.json");
  http.addHeader("Content-Type","application/json"); http.setTimeout(3000); http.POST(payload); http.end();
}

